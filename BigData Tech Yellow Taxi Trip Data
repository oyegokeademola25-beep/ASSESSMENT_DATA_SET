      "source": [
        "# ── Q3: Top 20 pickup-dropoff location pairs ────────────────────────────────\n",
        "# High-cardinality groupBy – triggers a significant shuffle\n",
        "od_pairs = df.groupBy('PULocationID', 'DOLocationID') \\\n",
