    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "IJyqh6uBLVou",
        "outputId": "e2b9dc15-954c-4153-90b1-ff833905b335"
      },
      "source": [
        "# ── 1.2 Drop unnecessary columns ───────────────────────────────────────────\n",
        "columns_to_drop = [\n",
        "    'store_and_fwd_flag',\n",
        "    'congestion_surcharge',\n",
        "    'airport_fee',\n",
        "    'improvement_surcharge'\n",
        "]\n",
        "# Only drop columns that actually exist in this dataset\n",
        "columns_to_drop = [c for c in columns_to_drop if c in df.columns]\n",
        "df = df.drop(*columns_to_drop)\n",
        "\n",
        "print(f'Columns after dropping: {df.columns}')"
      ],
      "execution_count": 5,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Columns after dropping: ['VendorID', 'tpep_pickup_datetime', 'tpep_dropoff_datetime', 'passenger_count', 'trip_distance', 'RatecodeID', 'PULocationID', 'DOLocationID', 'payment_type', 'fare_amount', 'extra', 'mta_tax', 'tip_amount', 'tolls_amount', 'total_amount', 'Airport_fee', 'cbd_congestion_fee']\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "FBImbiYHLVou",
        "outputId": "4ec927f9-64ff-45f8-f59d-577f4e9a9f34"
      },
      "source": [
        "# ── 1.3 Handle missing values ───────────────────────────────────────────────\n",
        "# Drop rows where critical columns are null\n",
        "critical_cols = ['tpep_pickup_datetime', 'tpep_dropoff_datetime',\n",
        "                 'trip_distance', 'total_amount']\n",
        "df = df.dropna(subset=critical_cols)\n",
        "\n",
        "# Impute passenger_count with median\n",
        "median_passengers = df.approxQuantile('passenger_count', [0.5], 0.01)[0]\n",
        "df = df.fillna({'passenger_count': int(median_passengers)})\n",
        "\n",
        "print(f'Records after null removal: {df.count():,}')"
      ],
      "execution_count": 6,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Records after null removal: 11,724,069\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "NIPQ6wEbLVou",
        "outputId": "b37e9a01-c3c3-4271-9379-3096335baece"
      },
      "source": [
        "# ── 1.4 Remove logically invalid rows ──────────────────────────────────────\n",
        "df = df.filter(\n",
        "    (col('trip_distance') > 0) &\n",
        "    (col('total_amount') > 0) &\n",
        "    (col('fare_amount') >= 2.50) &\n",
        "    (col('tpep_dropoff_datetime') > col('tpep_pickup_datetime'))\n",
        ")\n",
        "\n",
        "print(f'Records after logic filters: {df.count():,}')"
      ],
      "execution_count": 7,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Records after logic filters: 10,481,208\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "wnVk5zp1LVou",
        "outputId": "3f275308-2fad-4386-c2d9-6cf1812aea2a"
      },
      "source": [
        "# ── 1.5 IQR outlier removal on trip_distance and total_amount ──────────────\n",
        "q1_dist, q3_dist = df.approxQuantile('trip_distance', [0.25, 0.75], 0.01)\n",
        "iqr_dist = q3_dist - q1_dist\n",
        "\n",
        "q1_fare, q3_fare = df.approxQuantile('total_amount', [0.25, 0.75], 0.01)\n",
        "iqr_fare = q3_fare - q1_fare\n",
        "\n",
        "df = df.filter(\n",
        "    (col('trip_distance').between(\n",
        "        q1_dist - 1.5 * iqr_dist, q3_dist + 1.5 * iqr_dist)) &\n",
        "    (col('total_amount').between(\n",
        "        q1_fare - 1.5 * iqr_fare, q3_fare + 1.5 * iqr_fare))\n",
        ")\n",
        "\n",
        "print(f'Records after outlier removal: {df.count():,}')"
      ],
      "execution_count": 8,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Records after outlier removal: 9,110,182\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "48oLZms2LVou",
        "outputId": "eb7e72a2-18ab-4260-bd5a-b9558a763521"
      },
      "source": [
        "import pyspark.sql.functions as F\n",
        "# ── 1.6 Derive new features ─────────────────────────────────────────────────\n",
        "df = df.withColumn('trip_duration_min',\n",
        "    (F.unix_timestamp(col('tpep_dropoff_datetime')) -\n",
        "     F.unix_timestamp(col('tpep_pickup_datetime'))) / 60\n",
        ")\n",
        "df = df.withColumn('pickup_hour',  F.hour('tpep_pickup_datetime'))\n",
        "df = df.withColumn('pickup_day',   F.dayofweek('tpep_pickup_datetime'))\n",
        "df = df.withColumn('pickup_month', F.month('tpep_pickup_datetime'))\n",
        "\n",
        "# Remove implausible durations\n",
        "df = df.filter(col('trip_duration_min').between(1, 180))\n",
        "\n",
        "# Cache the cleaned DataFrame – avoids re-reading Parquet for every EDA query\n",
        "df.persist(StorageLevel.MEMORY_AND_DISK)\n",
        "clean_count = df.count()   # triggers caching\n",
        "print(f'✅ Final clean records cached: {clean_count:,}')\n",
        "df.show(5)"
      ],
