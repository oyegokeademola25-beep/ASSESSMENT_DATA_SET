    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "F74485FeLVou",
        "outputId": "f6dcd276-2a49-4c54-96b5-4545dc37f780"
      },
      "source": [
        "# ── 1.1 Load all three months into a single DataFrame ──────────────────────\n",
        "df = spark.read.parquet(PARQUET_PATH)\n",
        "\n",
        "print(f'Total raw records: {df.count():,}')\n",
        "print(f'Columns: {len(df.columns)}')\n",
        "df.printSchema()"
      ],
      "execution_count": 4,
